[Unit]
Description=Eavesdrop active-listener desktop dictation service
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=@REPO_ROOT@
ExecStart=/bin/bash -c 'set -a; [ -f @REPO_ROOT@/.env ] && source @REPO_ROOT@/.env; exec @ACTIVE_LISTENER_BIN@'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
