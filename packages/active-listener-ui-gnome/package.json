{
  "name": "active-listener-ui-gnome",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node esbuild.js",
    "install:extension": "npm run build && gnome-extensions install --force .out/eavesdrop@shyndman.ca.zip",
    "validate:transcript-controller": "node scripts/validate-transcript-controller.ts",
    "validate:transcript-planner": "node scripts/validate-transcript-planner.ts",
    "typecheck": "tsc --noEmit",
    "wayland:test": "npm run install:extension && dbus-run-session gnome-shell --devkit --wayland"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@girs/adw-1": "^1.10.0-4.0.0-rc.1",
    "@girs/gio-2.0": "2.88.0-4.0.0-rc.1",
    "@girs/gjs": "4.0.0-rc.1",
    "@girs/gnome-shell": "^49.1.0",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.1",
    "@girs/pango-1.0": "1.57.1-4.0.0-rc.4",
    "@girs/st-17": "^17.0.0-4.0.0-rc.1",
    "adm-zip": "^0.5.16",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.2"
  }
}
